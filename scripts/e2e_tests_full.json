        "mkdir -p site/demos/customer-voice && ./cmd/BonfyreTranscribe/bonfyre-transcribe site/demos/test_a.wav site/demos/customer-voice || true",
        "./cmd/BonfyreTone/bonfyre-tone extract site/demos/customer-voice/transcript.txt site/demos/customer-voice || true",
        "# bonfyre-tag requires a model; skip if not configured (user can supply model path)",
        "./cmd/BonfyreEmbed/bonfyre-embed --input-dir site/demos/customer-voice --out site/demos/customer-voice/embed.json || true"
      ],
      "expect": {
        "files": [
          "site/demos/customer-voice/transcript.json",
          "site/demos/customer-voice/transcript.txt",
          "site/demos/customer-voice/embed.json"
        ]
      }
    },
