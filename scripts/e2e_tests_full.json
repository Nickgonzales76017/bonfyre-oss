{
  "tests": [
    {
      "name": "shift-handoff-board-pipeline",
      "commands": [
        "mkdir -p site/demos/shift-handoff && ./cmd/BonfyreTranscribe/bonfyre-transcribe site/demos/test_a.wav site/demos/shift-handoff || true",
        "./cmd/BonfyreBrief/bonfyre-brief site/demos/shift-handoff/transcript.json site/demos/shift-handoff || true",
        "./cmd/BonfyreProof/bonfyre-proof bundle site/demos/shift-handoff site/demos/shift-handoff/proof_bundle || true",
        "./cmd/BonfyreOffer/bonfyre-offer generate site/demos/shift-handoff/proof_bundle site/demos/shift-handoff/offer_out || true",
        "./cmd/BonfyrePack/bonfyre-pack assemble site/demos/shift-handoff site/demos/shift-handoff/offer_out site/demos/shift-handoff/pack_out || true"
      ],
      "expect": {
        "files": [
          "site/demos/shift-handoff/transcript.json",
          "site/demos/shift-handoff/brief.md",
          "site/demos/shift-handoff/brief-meta.json",
          "site/demos/shift-handoff/pack_out"
        ]
      }
    },
    {
      "name": "memory-atlas-pipeline",
      "commands": [
        "mkdir -p site/demos/memory-atlas && ./cmd/BonfyreTranscribe/bonfyre-transcribe site/demos/test_b.wav site/demos/memory-atlas || true",
        "./cmd/BonfyreBrief/bonfyre-brief site/demos/memory-atlas/transcript.json site/demos/memory-atlas || true",
        "./cmd/BonfyreEmbed/bonfyre-embed --input-dir site/demos/memory-atlas --out site/demos/memory-atlas/embed.json || true",
        "./cmd/BonfyreRender/bonfyre-render artifact site/demos/memory-atlas/transcript.json site/demos/memory-atlas || true"
      ],
      "expect": {
        "files": [
          "site/demos/memory-atlas/transcript.json",
          "site/demos/memory-atlas/brief.md",
          "site/demos/memory-atlas/embed.json",
          "site/demos/memory-atlas/artifact.json"
        ]
      }
    },
